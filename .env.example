# AionScript Website Environment Variables
# Copy this file to .env and fill in your values

# ============ STRIPE (Payment Processing) ============
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs (create these in Stripe dashboard)
VITE_STRIPE_PRO_PRICE_ID=price_your_pro_monthly_price_id
VITE_STRIPE_TEAM_PRICE_ID=price_your_team_monthly_price_id

# ============ AION PLATFORM API ============
# Your AionDB platform API URL (for tenant provisioning)
VITE_AION_API_URL=https://api.aionscript.com
AION_API_URL=https://api.aionscript.com

# Platform API key (for authenticated requests from Netlify functions)
AION_SERVICE_KEY=your_platform_service_key

# ============ RESEND (Contact Form) ============
RESEND_API_KEY=re_your_resend_api_key
CONTACT_TO_EMAIL=your-email@domain.com
CONTACT_FROM_EMAIL=contact@yourdomain.com
CONTACT_SUBJECT_PREFIX=AionScript Contact

# ============ SITE URL ============
# Used for Stripe success/cancel URLs
URL=https://aionscript.com
